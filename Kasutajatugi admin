            button { width: 100%; padding: 10px; background: #0d6efd; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; }
            .error { color: #842029; background: #f8d7da; padding: 10px; border-radius: 4px; margin-bottom: 15px; text-align: center; }
        </style>
    </head>
