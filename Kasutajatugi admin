            </form>
            <p style="text-align:center; margin-top:15px;"><a href="index.php">Tagasi avalikule lehele</a></p>
        </div>
    </body>
    </html>
    <?php
    exit;
}

// --- ADMIN TEGEVUSED (NÕUTUD FUNKTSIONAALSUS) ---

// 1. NÕUE: Kustutada pöördumine andmebaasist jäädavalt
if (isset($_GET['delete'])) {
    $id = (int)$_GET['delete'];
    $stmt = $pdo->prepare("DELETE FROM poorduumised WHERE id = ?");
    $stmt->execute([$id]);
    header("Location: admin.php");
    exit;
}

// 2. NÕUE: Muuta pöördumise staatust
if (isset($_POST['update_status'])) {
    $id = (int)$_POST['id'];
    $uus_staatus = $_POST['staatus'];
    $stmt = $pdo->prepare("UPDATE poorduumised SET staatus = ? WHERE id = ?");
    $stmt->execute([$uus_staatus, $id]);
    header("Location: admin.php");
    exit;
}

// 3. NÕUE: Lisada uue pöördumise administraatori poolt
if (isset($_POST['add_ticket'])) {
    $nimi = trim($_POST['nimi']);
    $osakond = trim($_POST['osakond']);
    $kontakt = trim($_POST['kontakt']);
    $kirjeldus = trim($_POST['kirjeldus']);
    $staatus = $_POST['staatus'];

    if (!empty($nimi) && !empty($osakond) && !empty($kontakt) && !empty($kirjeldus)) {
        $stmt = $pdo->prepare('INSERT INTO poorduumised (nimi, osakond, kontakt, kirjeldus, staatus) VALUES (?, ?, ?, ?, ?)');
        $stmt->execute([$nimi, $osakond, $kontakt, $kirjeldus, $staatus]);
    }
    header("Location: admin.php");
    exit;
}

// 4. NÕUE: Kuvada kõiki pöördumisi
$tickets = $pdo->query("SELECT * FROM poorduumised ORDER BY id DESC")->fetchAll();
