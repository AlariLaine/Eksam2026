<?php
// /var/www/html/admin.php
session_start();
ini_set('display_errors', 1);
error_reporting(E_ALL);
require_once 'db.php';

// NÕUE: Sisselogimise kontroll ANDMEBAASIST koos hashitud parooli kontrolliga
if (isset($_POST['login'])) {
    $username = trim($_POST['username'] ?? '');
    $password = $_POST['password'] ?? '';
    
    // 1. Küsime andmebaasist kasutaja andmed AINULT kasutajanime järgi
    $stmt = $pdo->prepare("SELECT * FROM kasutajad WHERE kasutajanimi = ?");
    $stmt->execute([$username]);
    $user = $stmt->fetch();
    
    // 2. password_verify võrdleb vormi sisestatud teksti ja andmebaasi salvestatud räsi
    if ($user && password_verify($password, $user['parool'])) {
        $_SESSION['admin_logged_in'] = true;
        $_SESSION['admin_user'] = $user['kasutajanimi'];
    } else {
        $viga = "Vale kasutajanimi või parool!";
    }
}

// Väljalogimine
if (isset($_GET['logout'])) {
    session_destroy();
    header("Location: admin.php");
    exit;
}

// Kui pole sisse logitud, kuvatakse sisselogimise vorm
if (!isset($_SESSION['admin_logged_in'])) {
    ?>
